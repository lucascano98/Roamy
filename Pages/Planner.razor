@page "/planner/{TripId:guid}"
@inject TripManager TripManager
@implements IDisposable


<PageTitle>Trip Planner</PageTitle>

@if (TripManager.CurrentTrip == null)
{
    <p>Loading...</p>
    return;
}

<div class="page">
    <div class="left-column">

        <button @onclick="() => SetPanel(ActivePanel.Map)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#FF3B30">
                <path fill-rule="evenodd" d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
            </svg>
        </button>

        <button @onclick="() => SetPanel(ActivePanel.Shortlist)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#FBC02D">
                <path fill-rule="evenodd" d="M6.32 2.577a49.255 49.255 0 0 1 11.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 0 1-1.085.67L12 18.089l-7.165 3.583A.75.75 0 0 1 3.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93Z" clip-rule="evenodd" />
            </svg>
        </button>

    </div>

    <div class="center-column">

        <div class="header">
            <h1>@TripManager.CurrentTrip.Name</h1>
            <div class="header-details">

                <h2>@TripManager.CurrentTrip.Location[0].City, @TripManager.CurrentTrip.Location[0].Country</h2>

                <div class="header-divider"></div>

                <h2>@TripManager.CurrentTrip.StartDate.ToString("MMM dd") - @TripManager.CurrentTrip.EndDate.ToString("MMM dd, yyyy")</h2>
                
                <div class="header-divider"></div>
                
                <p>@TripManager.CurrentTrip.Days.Count(d => d.Activities.Any()) of @TripManager.CurrentTrip.Days.Count days planned</p>
            
            </div>
        </div>

        <div class="itinerary">

            <div class="navigation">

                <button class="left-arrow" @onclick="PreviousDay" disabled="@(selectedDate == TripManager.CurrentTrip.StartDate)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm-4.28 9.22a.75.75 0 0 0 0 1.06l3 3a.75.75 0 1 0 1.06-1.06l-1.72-1.72h5.69a.75.75 0 0 0 0-1.5h-5.69l1.72-1.72a.75.75 0 0 0-1.06-1.06l-3 3Z" clip-rule="evenodd" />
                    </svg>
                </button>

                <div class="navigation-center">
                    <p class="day-number">Day @dayNumber</p>
                    <p class="day-date">@selectedDate.ToString("ddd, MM/dd")</p>
                </div>

                <button class="right-arrow" @onclick="NextDay" disabled="@(selectedDate == TripManager.CurrentTrip.EndDate)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm4.28 10.28a.75.75 0 0 0 0-1.06l-3-3a.75.75 0 1 0-1.06 1.06l1.72 1.72H8.25a.75.75 0 0 0 0 1.5h5.69l-1.72 1.72a.75.75 0 1 0 1.06 1.06l3-3Z" clip-rule="evenodd" />
                    </svg>
                </button>

            </div>

            <div class="time-grid">
                @{
                    var currentDay = TripManager.CurrentTrip.GetDayByDate(selectedDate);
                    var scheduledActivities = currentDay?.Activities.Where(a => a.StartTime != null).ToList() ?? new List<Activity>();
                }

                @for (int i = 0; i <= 95; i++)
                {
                    <div class="label">
                        @if (i % 4 == 0)
                        {
                            <p>@DateTime.Today.Add(TimeSpan.FromMinutes(i * 15)).ToString("h:mm tt")</p>
                        }
                    </div>
                    <div class="events @(i % 4 == 0 ? "hour-mark" : i % 2 == 0 ? "half-hour-mark" : "") @(i == 95 ? "last-row" : "")">
                    </div>
                }

                @foreach(var activity in scheduledActivities)
                {
                    <div class="activity-card @GetCategoryClass(activity.Category)"
                         style="left:60px; right:0; top:@GetTopPx(activity.StartTime.Value); height:@GetHeightPx(activity.Duration.Value);"
                         @onclick="() => OpenEditModal(activity)">
                        @activity.Name
                    </div>
                }

            </div>

            @if (showModal)
            {
                @*Event callbacks to the ActivityModal*@
                <ActivityModal Activity="activityToEdit" SelectedDate="selectedDate" OnSave="HandleSave" OnCancel="HandleCancel" OnDelete="HandleDelete"/>
            }

        </div>

        <button  @onclick="OpenAddModal"  class="fab-modal">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 9a.75.75 0 0 0-1.5 0v2.25H9a.75.75 0 0 0 0 1.5h2.25V15a.75.75 0 0 0 1.5 0v-2.25H15a.75.75 0 0 0 0-1.5h-2.25V9Z" clip-rule="evenodd" />
            </svg>
        </button>

    </div>

    <div class="right-column">
        @if (currentPanel == ActivePanel.Map)
        {
            <MapPanel />
        }
        else if(currentPanel == ActivePanel.Shortlist)
        {
            <div class="shortlist">
                <h2>Shortlist</h2>

                @if (!TripManager.CurrentTrip.Shortlist.Any())
                {
                    <p>No activities saved yet</p>
                }
                else
                {
                    foreach (var activity in TripManager.CurrentTrip.Shortlist)
                    {
                        <div class="shortlist-item" @onclick="() => OpenEditModal(activity)">
                            <p class="shortlist-name">@activity.Name</p>
                            <p class="shortlist-category">@GetCategoryDisplayName(activity.Category ?? ActivityCategory.Other)</p>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid TripId {get; set;}
    enum ActivePanel { None, Map, Shortlist }

    private ActivePanel currentPanel = ActivePanel.Shortlist; //default panel is the shortlist

    private void SetPanel(ActivePanel panel)
    {
        currentPanel = panel;
    }

    private DateTime selectedDate;
    private int dayNumber;

    //Runs once the program is initialized (before screen renders)
    //Protected is only accessible within Planner and inherited classes
    protected override async Task OnInitializedAsync()
    {
        await TripManager.GetTripAsync(TripId);
        selectedDate = TripManager.CurrentTrip.StartDate.Date;
        UpdateDayNumber();
        TripManager.OnChange += StateHasChanged;
    }

    public void Dispose() 
    {
        TripManager.OnChange -= StateHasChanged;
    }

    //Find the Grid row for a certain time (1440 min/day, with a row every 15 minutes = 96 rows)
    private int GetGridRow(TimeSpan startTime )
    {
        return (int)(startTime.TotalMinutes / 15) + 1;
    }

    //Finds the height (span) of an activity card based on duration
    private int GetGridRowSpan(TimeSpan duration)
    {
        if (duration.TotalMinutes <= 0)
        {
            return 1;
        }
        return (int)Math.Ceiling(duration.TotalMinutes / 15); //round up to properly fill in the card
    }

    // use percent of the day so placement of activity card scales with container height
    private string GetTopPx(TimeSpan startTime)
    {
        var percent = startTime.TotalMinutes / 1440.0 * 100.0; // 1440 minutes in a day
        return $"{percent.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)}%"; //creates 4 decimal places with no trailing 0s. Also uses a '.' for decimal regardless of regional setting as to not break CSS.
    }

    // find the height of the activity card
    private string GetHeightPx(TimeSpan duration)
    {
        var percent = duration.TotalMinutes / 1440.0 * 100.0;
        if (percent <= 0.1) // ensure something visible for very short durations
            percent = 0.1;
        return $"{percent.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)}%";
    }

    private void PreviousDay()
    {
        if (selectedDate != TripManager.CurrentTrip.StartDate)
        {
            selectedDate = selectedDate.AddDays(-1);
            UpdateDayNumber();
        }
    }

    private void NextDay()
    {
        if (selectedDate != TripManager.CurrentTrip.EndDate)
        {
            selectedDate = selectedDate.AddDays(1);
            UpdateDayNumber();
        }
    }

    private void UpdateDayNumber()
    {
        dayNumber = TripManager.CurrentTrip.Days[
            TripManager.CurrentTrip.Days.FindIndex(d => d.Date.Date == selectedDate.Date)
        ].DayNumber;
    }

    private bool showModal = false;
    private Activity? activityToEdit = null;

    private void OpenAddModal()
    {
        activityToEdit = null;
        showModal = true;
    }

    private void OpenEditModal(Activity activity)
    {
        activityToEdit = activity;
        showModal = true;
    }

    private void HandleCancel()
    {
        showModal = false;
    }

    private async Task HandleDelete(Activity activity)
    {
        await TripManager.DeleteActivity(activity);
        showModal = false;
    }

    //Async method that deletes an activity, closes the modal, and signals that it has completed.
    private async Task HandleSave(Activity activity) //EventCallBack handlers should return Task
    {
        if (activityToEdit == null)
            await TripManager.AddActivity(activity);
        else
        {
            Console.WriteLine($"Editing activity: {activity.ActivityId}");
            await TripManager.EditActivity(activity);
        }

        showModal = false;
        StateHasChanged();
    }

    //decides class name for activity-card based on category
    private string GetCategoryClass(ActivityCategory? category) => category switch
    {
        ActivityCategory.Sightseeing => "cat-sightseeing",
        ActivityCategory.FoodAndDrink => "cat-food",
        ActivityCategory.Transport => "cat-transport",
        ActivityCategory.Lodging => "cat-lodging",
        ActivityCategory.Event => "cat-event",
        _ => "cat-other"
    };

    private string GetCategoryDisplayName(ActivityCategory category) => category switch
    {
        ActivityCategory.FoodAndDrink => "Food & Drink",
        _ => category.ToString()
    };
}
